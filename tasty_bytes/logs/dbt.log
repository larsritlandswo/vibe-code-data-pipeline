create dynamic table LARSR_DB.PROD.int_order_details_enriched
        target_lag = '1 hour'
        warehouse = LARSR_WH
        refresh_mode = AUTO

        initialize = ON_CREATE

        as (
            SELECT
    od.ORDER_DETAIL_ID,
    od.ORDER_ID,
    o.TRUCK_ID,
    o.LOCATION_ID,
    o.CUSTOMER_ID,
    o.ORDER_TS,
    o.ORDER_DATE,
    o.ORDER_CHANNEL,
    o.ORDER_CURRENCY,
    o.ORDER_TOTAL,
    o.ORDER_TAX_AMOUNT,
    o.ORDER_DISCOUNT_AMOUNT,
    od.MENU_ITEM_ID,
    m.MENU_ITEM_NAME,
    m.MENU_TYPE,
    m.TRUCK_BRAND_NAME,
    m.ITEM_CATEGORY,
    m.ITEM_SUBCATEGORY,
    od.QUANTITY,
    od.UNIT_PRICE,
    od.PRICE AS LINE_TOTAL,
    m.COST_OF_GOODS_USD,
    od.QUANTITY * m.COST_OF_GOODS_USD AS LINE_COGS,
    od.PRICE - (od.QUANTITY * m.COST_OF_GOODS_USD) AS LINE_PROFIT,
    od.ORDER_ITEM_DISCOUNT_AMOUNT
FROM LARSR_DB.PROD.stg_order_details od
INNER JOIN LARSR_DB.PROD.stg_orders o ON od.ORDER_ID = o.ORDER_ID
INNER JOIN LARSR_DB.PROD.stg_menu m ON od.MENU_ITEM_ID = m.MENU_ITEM_ID
        )
