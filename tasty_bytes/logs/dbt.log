    f.COUNTRY AS FRANCHISE_COUNTRY
FROM LARSR_DB.PROD.stg_trucks t
LEFT JOIN LARSR_DB.PROD.stg_franchises f ON t.FRANCHISE_ID = f.FRANCHISE_ID
        )
