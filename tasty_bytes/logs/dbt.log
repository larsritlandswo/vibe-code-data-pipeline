create or replace semantic view LARSR_DB.PROD.sem_sales_analytics
  

TABLES (
    daily_sales AS LARSR_DB.PROD.fct_daily_sales PRIMARY KEY (order_date, truck_id, location_id),
    orders AS LARSR_DB.PROD.fct_order_summary PRIMARY KEY (order_id),
    trucks AS LARSR_DB.PROD.dim_truck PRIMARY KEY (truck_id),
    locations AS LARSR_DB.PROD.dim_location PRIMARY KEY (location_id),
    menu AS LARSR_DB.PROD.dim_menu PRIMARY KEY (menu_item_id),
    customers AS LARSR_DB.PROD.dim_customer PRIMARY KEY (customer_id)
)

RELATIONSHIPS (
    daily_sales_to_trucks AS daily_sales(truck_id) REFERENCES trucks(truck_id),
    daily_sales_to_locations AS daily_sales(location_id) REFERENCES locations(location_id),
    orders_to_trucks AS orders(truck_id) REFERENCES trucks(truck_id),
    orders_to_locations AS orders(location_id) REFERENCES locations(location_id),
    orders_to_customers AS orders(customer_id) REFERENCES customers(customer_id)
)

DIMENSIONS (
    daily_sales.order_date AS daily_sales.order_date
        WITH SYNONYMS = ('date', 'sale date', 'day'),
    trucks.truck_id AS trucks.truck_id,
    trucks.primary_city AS trucks.primary_city
        WITH SYNONYMS = ('truck city', 'home city'),
    trucks.region AS trucks.region
        WITH SYNONYMS = ('truck region'),
    trucks.country AS trucks.country
        WITH SYNONYMS = ('truck country'),
    trucks.make AS trucks.make
        WITH SYNONYMS = ('truck make', 'manufacturer'),
    trucks.model AS trucks.model
        WITH SYNONYMS = ('truck model'),
    trucks.ev_flag AS trucks.ev_flag
        WITH SYNONYMS = ('electric vehicle', 'is ev'),
    trucks.franchise_flag AS trucks.franchise_flag
        WITH SYNONYMS = ('is franchise'),
    trucks.franchise_owner AS trucks.franchise_owner,
    locations.location_name AS locations.location_name
        WITH SYNONYMS = ('venue', 'place'),
    locations.city AS locations.city
        WITH SYNONYMS = ('location city'),
    locations.region AS locations.region
        WITH SYNONYMS = ('location region'),
    locations.country AS locations.country
        WITH SYNONYMS = ('location country'),
    orders.order_date AS orders.order_date
        WITH SYNONYMS = ('order date'),
    orders.order_channel AS orders.order_channel
        WITH SYNONYMS = ('channel', 'sales channel'),
    orders.order_currency AS orders.order_currency
        WITH SYNONYMS = ('currency'),
    customers.city AS customers.city
        WITH SYNONYMS = ('customer city'),
    customers.country AS customers.country
        WITH SYNONYMS = ('customer country'),
    customers.gender AS customers.gender,
    customers.favourite_brand AS customers.favourite_brand
        WITH SYNONYMS = ('preferred brand', 'favorite brand'),
    customers.marital_status AS customers.marital_status
)

METRICS (
    daily_sales.total_revenue AS SUM(daily_sales.total_revenue)
        WITH SYNONYMS = ('total sales', 'gross revenue', 'revenue'),
    daily_sales.total_cogs AS SUM(daily_sales.total_cogs)
        WITH SYNONYMS = ('cost of goods sold', 'cogs'),
    daily_sales.total_gross_profit AS SUM(daily_sales.total_gross_profit)
        WITH SYNONYMS = ('gross profit', 'profit'),
    daily_sales.total_orders AS SUM(daily_sales.order_count)
        WITH SYNONYMS = ('number of orders', 'order count'),
    daily_sales.total_items_sold AS SUM(daily_sales.items_sold)
        WITH SYNONYMS = ('quantity sold', 'units sold'),
    daily_sales.total_unique_customers AS SUM(daily_sales.unique_customers)
        WITH SYNONYMS = ('customer count'),
    daily_sales.average_order_value AS AVG(daily_sales.avg_order_value)
        WITH SYNONYMS = ('aov', 'avg order value'),
    orders.order_total_revenue AS SUM(orders.order_total)
        WITH SYNONYMS = ('order revenue'),
    orders.order_gross_profit AS SUM(orders.total_gross_profit)
        WITH SYNONYMS = ('order profit'),
    orders.avg_items_per_order AS AVG(orders.total_quantity)
        WITH SYNONYMS = ('basket size', 'items per order')
)

COMMENT = 'Tasty Bytes food truck analytics: sales performance, truck operations, customer behavior, and menu analysis.'

AI_SQL_GENERATION 'Focus on daily_sales for trend analysis and aggregated KPIs. Use orders for order-level detail. Revenue is in USD. Date range is 2019-01-01 to 2022-11-01.'
